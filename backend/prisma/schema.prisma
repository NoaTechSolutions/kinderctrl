enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  ACHIEVED
  NEEDS_SUPPORT
}

model Immunization {
  id      String @id @default(uuid()) @db.Uuid
  childId String @map("child_id") @db.Uuid
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  vaccineName String  @map("vaccine_name")
  vaccineType String? @map("vaccine_type")

  doseNumber Int? @map("dose_number")
  totalDoses Int? @map("total_doses")

  administeredDate DateTime  @map("administered_date") @db.Date
  nextDoseDueDate  DateTime? @map("next_dose_due_date") @db.Date
  expirationDate   DateTime? @map("expiration_date") @db.Date

  administeredBy String? @map("administered_by")
  lotNumber      String? @map("lot_number")
  certificateUrl String? @map("certificate_url")

  isUpToDate       Boolean          @default(true) @map("is_up_to_date")
  complianceStatus ComplianceStatus @default(COMPLIANT) @map("compliance_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([childId])
  @@index([expirationDate])
  @@map("immunizations")
}

enum ComplianceStatus {
  COMPLIANT
  PENDING
  OVERDUE
  EXEMPT
}

