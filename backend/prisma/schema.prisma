model PricingConfig {
  id       String @id @default(uuid()) @db.Uuid
  centerId String @unique @map("center_id") @db.Uuid
  center   Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  infantMonthly  Decimal @map("infant_monthly") @db.Decimal(10, 2)
  toddlerMonthly Decimal @map("toddler_monthly") @db.Decimal(10, 2)
  prekMonthly    Decimal @map("prek_monthly") @db.Decimal(10, 2)

  siblingDiscountPct Int     @default(10) @map("sibling_discount_pct")
  registrationFee    Decimal @map("registration_fee") @db.Decimal(10, 2)
  latePickupFee15min Decimal @map("late_pickup_fee_15min") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pricing_config")
}

model Invoice {
  id       String @id @default(uuid()) @db.Uuid
  centerId String @map("center_id") @db.Uuid
  center   Center @relation(fields: [centerId], references: [id])

  parentId String @map("parent_id") @db.Uuid
  parent   Parent @relation(fields: [parentId], references: [id])

  childId String @map("child_id") @db.Uuid
  child   Child  @relation(fields: [childId], references: [id])

  invoiceDate DateTime @map("invoice_date") @db.Date
  dueDate     DateTime @map("due_date") @db.Date

  subtotal       Decimal @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(10, 2)
  totalAmount    Decimal @map("total_amount") @db.Decimal(10, 2)

  status InvoiceStatus @default(PENDING)
  pdfUrl String?       @map("pdf_url")

  lateFeeApplied Boolean @default(false) @map("late_fee_applied")

  invoiceItems InvoiceItem[]
  payment      Payment?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  paidAt    DateTime? @map("paid_at")

  @@index([parentId, status])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model InvoiceItem {
  id        String  @id @default(uuid()) @db.Uuid
  invoiceId String  @map("invoice_id") @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  amount      Decimal @db.Decimal(10, 2)

  @@map("invoice_items")
}

model Payment {
  id        String  @id @default(uuid()) @db.Uuid
  invoiceId String  @unique @map("invoice_id") @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  amount Decimal       @db.Decimal(10, 2)
  method PaymentMethod

  stripePaymentIntentId String? @map("stripe_payment_intent_id")
  stripeChargeId        String? @map("stripe_charge_id")

  status PaymentStatus @default(PENDING)

  paidAt    DateTime @map("paid_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("payments")
}

enum PaymentMethod {
  STRIPE_CARD
  STRIPE_ACH
  PAYPAL
  VENMO
  ZELLE
  CASH
  CHECK
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

