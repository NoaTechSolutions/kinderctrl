enum EntityType {
  CHILD
  STAFF
  CENTER
}

enum DocumentStatus {
  ACTIVE
  EXPIRED
  ARCHIVED
}

// ============================================
// STAFF ATTENDANCE & TIME TRACKING
// ============================================

model StaffTimeEntry {
  id                String      @id @default(uuid()) @db.Uuid
  staffId           String      @map("staff_id") @db.Uuid
  staff             Staff       @relation(fields: [staffId], references: [id], onDelete: Cascade)
  centerId          String      @map("center_id") @db.Uuid
  center            Center      @relation(fields: [centerId], references: [id])
  date              DateTime    @db.Date
  type              PunchType
  deviceTimestamp   DateTime    @map("device_timestamp")
  serverReceivedAt  DateTime?   @map("server_received_at")
  timeDriftDetected Boolean     @default(false) @map("time_drift_detected")
  latitude          Float?
  longitude         Float?
  withinGeoFence    Boolean?    @map("within_geo_fence")
  source            PunchSource @default(APP)
  isCorrection      Boolean     @default(false) @map("is_correction")
  correctionId      String?     @map("correction_id") @db.Uuid
  correction        CorrectionRequest? @relation(fields: [correctionId], references: [id])

  createdAt         DateTime    @default(now()) @map("created_at")

  @@unique([staffId, centerId, date, type])
  @@index([staffId, date])
  @@index([centerId, date])
  @@map("staff_time_entries")
}

model CorrectionRequest {
  id                  String            @id @default(uuid()) @db.Uuid
  staffId             String            @map("staff_id") @db.Uuid
  staff               Staff             @relation(fields: [staffId], references: [id], onDelete: Cascade)
  centerId            String            @map("center_id") @db.Uuid
  center              Center            @relation(fields: [centerId], references: [id])
  date                DateTime          @db.Date
  status              CorrectionStatus  @default(PENDING)

  originalClockIn     DateTime?         @map("original_clock_in")
  originalBreakIn     DateTime?         @map("original_break_in")
  originalBreakOut    DateTime?         @map("original_break_out")
  originalClockOut    DateTime?         @map("original_clock_out")

  requestedClockIn    DateTime?         @map("requested_clock_in")
  requestedBreakIn    DateTime?         @map("requested_break_in")
  requestedBreakOut   DateTime?         @map("requested_break_out")
  requestedClockOut   DateTime?         @map("requested_clock_out")

  staffComment        String            @map("staff_comment")
  directorComment     String?           @map("director_comment")
  reviewedBy          String?           @map("reviewed_by") @db.Uuid
  reviewedAt          DateTime?         @map("reviewed_at")

  expiresAt           DateTime          @map("expires_at")
  createdAt           DateTime          @default(now()) @map("created_at")

  affectedEntries     StaffTimeEntry[]

  @@index([staffId, status])
  @@index([centerId, status])
  @@map("correction_requests")
}

model Schedule {
  id          String         @id @default(uuid()) @db.Uuid
  staffId     String         @map("staff_id") @db.Uuid
  staff       Staff          @relation(fields: [staffId], references: [id], onDelete: Cascade)
  centerId    String         @map("center_id") @db.Uuid
  center      Center         @relation(fields: [centerId], references: [id])
  startDate   DateTime       @map("start_date") @db.Date
  endDate     DateTime       @map("end_date") @db.Date
  status      ScheduleStatus @default(DRAFT)
  approvedBy  String?        @map("approved_by") @db.Uuid
  approvedAt  DateTime?      @map("approved_at")

  days        ScheduleDay[]

  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@unique([staffId, centerId, startDate])
  @@index([staffId, startDate])
  @@index([centerId, startDate])
  @@map("schedules")
}

model ScheduleDay {
  id          String    @id @default(uuid()) @db.Uuid
  scheduleId  String    @map("schedule_id") @db.Uuid
  schedule    Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  dayOfWeek   Int       @map("day_of_week") // ISO 8601: 1=Mon, 7=Sun
  startTime   String?   @map("start_time")  // "08:00"
  endTime     String?   @map("end_time")    // "16:00"
  isOff       Boolean   @default(false) @map("is_off")

  @@unique([scheduleId, dayOfWeek])
  @@map("schedule_days")
}

model PayrollSettings {
  id                      String       @id @default(uuid()) @db.Uuid
  centerId                String       @unique @map("center_id") @db.Uuid
  center                  Center       @relation(fields: [centerId], references: [id], onDelete: Cascade)
  frequency               PayFrequency @default(WEEKLY)
  breakPaid               Boolean      @default(false) @map("break_paid")
  overtimeDailyThreshold  Int          @default(8) @map("overtime_daily_threshold")
  overtimeWeeklyThreshold Int          @default(40) @map("overtime_weekly_threshold")
  overtimeRate            Float        @default(1.5) @map("overtime_rate")

  createdAt               DateTime     @default(now()) @map("created_at")
  updatedAt               DateTime     @updatedAt @map("updated_at")

  @@map("payroll_settings")
}

model PayrollPeriod {
  id          String       @id @default(uuid()) @db.Uuid
  centerId    String       @map("center_id") @db.Uuid
  center      Center       @relation(fields: [centerId], references: [id])
  startDate   DateTime     @map("start_date") @db.Date
  endDate     DateTime     @map("end_date") @db.Date
  status      PeriodStatus @default(OPEN)
  // The pay-frequency this period was created under — lets the history be
  // filtered by type (Weekly/Biweekly/Monthly). Set from PayrollSettings at
  // creation; defaults to WEEKLY for any pre-existing rows.
  frequency   PayFrequency @default(WEEKLY)
  approvedBy  String?      @map("approved_by") @db.Uuid
  approvedAt  DateTime?    @map("approved_at")

  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([centerId, startDate])
  @@map("payroll_periods")
}

model PayrollAdjustment {
  id       String   @id @default(uuid()) @db.Uuid
  staffId  String   @map("staff_id") @db.Uuid
  staff    Staff    @relation(fields: [staffId], references: [id])
  centerId String   @map("center_id") @db.Uuid
  center   Center   @relation(fields: [centerId], references: [id])
  date     DateTime @db.Date

  // Snapshot of the original punches at edit time (audit trail).
  originalClockIn  DateTime? @map("original_clock_in")
  originalClockOut DateTime? @map("original_clock_out")
  originalBreakIn  DateTime? @map("original_break_in")
  originalBreakOut DateTime? @map("original_break_out")

  // Director-adjusted values applied to the payroll calculation.
  adjustedClockIn  DateTime? @map("adjusted_clock_in")
  adjustedClockOut DateTime? @map("adjusted_clock_out")
  adjustedBreakIn  DateTime? @map("adjusted_break_in")
  adjustedBreakOut DateTime? @map("adjusted_break_out")

  reason     String
  adjustedBy String   @map("adjusted_by") @db.Uuid
  adjuster   User     @relation("PayrollAdjuster", fields: [adjustedBy], references: [id])
  adjustedAt DateTime @default(now()) @map("adjusted_at")

  // One active adjustment per staff per day (latest edit wins via upsert).
  @@unique([staffId, date])
  @@index([centerId, date])
  @@map("payroll_adjustments")
}

model KioskSettings {
  id                String    @id @default(uuid()) @db.Uuid
  centerId          String    @unique @map("center_id") @db.Uuid
  center            Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  pin                 String
  isEnabled           Boolean   @default(false) @map("is_enabled")
  timeoutMin          Int       @default(2) @map("timeout_min")
  kioskSessionToken   String?   @map("kiosk_session_token")
  failedPinAttempts   Int       @default(0) @map("failed_pin_attempts")
  pinResetToken       String?   @unique @map("pin_reset_token")
  pinResetTokenExpiry DateTime? @map("pin_reset_token_expiry")

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("kiosk_settings")
}

// Director's approval of a staff's worked hours on a given day. Created
// (or upserted) when the director marks a day or a full week as APPROVED /
// REJECTED in the Team Clock view. The unique([staffId, centerId, date])
// constraint keeps one record per (staff, day). weekStart is denormalized
// so the UI can query a whole week's approval status in one round-trip.
model AttendanceApproval {
  id              String         @id @default(uuid()) @db.Uuid
  staffId         String         @map("staff_id") @db.Uuid
  staff           Staff          @relation(fields: [staffId], references: [id], onDelete: Cascade)
  centerId        String         @map("center_id") @db.Uuid
  center          Center         @relation(fields: [centerId], references: [id])
  date            DateTime       @db.Date
  weekStart       DateTime       @map("week_start") @db.Date
  status          ApprovalStatus @default(PENDING)
  directorComment String?        @map("director_comment")
  reviewedBy      String?        @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime?      @map("reviewed_at")

  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@unique([staffId, centerId, date])
  @@index([centerId, weekStart])
  @@index([staffId, weekStart])
  @@map("attendance_approvals")
}

enum PunchType {
  CLOCK_IN
  BREAK_IN
  BREAK_OUT
  CLOCK_OUT
}

enum PunchSource {
  APP
  KIOSK
}

enum CorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ScheduleStatus {
  DRAFT
  APPROVED
}

enum PayFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum PeriodStatus {
  OPEN
  APPROVED
  EXPORTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
