  @@index([recipientId])
  @@index([type])
  @@index([status])
  @@map("notifications")
}

enum NotificationPriority {
  NORMAL
  HIGH
  URGENT
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

