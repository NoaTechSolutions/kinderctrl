  milestoneName String            @map("milestone_name")
  category      MilestoneCategory
  subcategory   String?

  ageMonthsMin Int @map("age_months_min")
  ageMonthsMax Int @map("age_months_max")

  standard   String? // CDC, OMS, Custom
  isRequired Boolean @default(false) @map("is_required")
  isActive   Boolean @default(true) @map("is_active")

  childMilestones ChildMilestone[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("milestones_config")
}

enum MilestoneCategory {
  PHYSICAL
  COGNITIVE
  SOCIAL_EMOTIONAL
  SELF_CARE
  LANGUAGE
}

model ChildMilestone {
  id      String @id @default(uuid()) @db.Uuid
  childId String @map("child_id") @db.Uuid
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

