// This is your Prisma schema file
// KinderCtrl - Complete Database Schema
// PostgreSQL 15+ with Prisma 7.x

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE: AUTHENTICATION & USERS
// ============================================

model User {
  id       String     @id @default(uuid()) @db.Uuid
  email    String     @unique
  // Nullable since PO QA #30 (Opción E): SUPER_ADMIN can create a User
  // for a staff member without a password. The user receives an email
  // with a tokenized setup link and supplies their own password via
  // POST /auth/reset-password (reusing the existing reset flow with
  // 7-day expiry for admin-triggered first-setup tokens).
  // Login enforces: password=null behaves IDENTICALLY to wrong-password
  // for the response shape — no enumeration leak.
  password String?
  role     UserRole
  status   UserStatus @default(PENDING_ACTIVATION)

  // Self-service profile fields for the /profile module (Issue #6).
  // Populated by PATCH /auth/me/profile. For STAFF role the satellite
  // Staff record already carries firstName/lastName/phone — the auth
  // service route-dispatches reads/writes there. For DIRECTOR /
  // SUPER_ADMIN there is no satellite, so the User row IS the source of
  // truth. PARENT will follow when its profile surface ships.
  firstName String? @map("first_name") @db.VarChar(100)
  lastName  String? @map("last_name") @db.VarChar(100)
  phone     String? @db.VarChar(20)

  // Profile v2 — preferences. Theme + language stay client-only
  // (localStorage); only timeFormat persists server-side so the value
  // survives device changes and pre-renders correctly on first paint.
  // Default = TWENTY_FOUR_HOUR to match the existing client default
  // (frontend/src/lib/preferences/time-format.tsx) — flipping it would
  // silently regress every existing user's preference on first server
  // hydrate.
  timeFormat TimeFormat @default(TWENTY_FOUR_HOUR) @map("time_format")

  // Profile v2/v6 — primary + secondary emergency contacts for
  // DIRECTOR / SUPER_ADMIN. STAFF keeps reading/writing the Staff
  // satellite (which has the same two-contact pair). Relationship is
  // free-text-with-whitelist (validated at DTO boundary) so adding
  // options later is a no-migration change. v6 added the secondary
  // contact columns so the User row matches the Staff satellite for
  // every role that lands on the User-side dispatch.
  emergencyContactName         String? @map("emergency_contact_name") @db.VarChar(100)
  emergencyContactPhone        String? @map("emergency_contact_phone") @db.VarChar(20)
  emergencyContactRelationship String? @map("emergency_contact_relationship") @db.VarChar(20)
  emergencyContact2Name         String? @map("emergency_contact_2_name") @db.VarChar(100)
  emergencyContact2Phone        String? @map("emergency_contact_2_phone") @db.VarChar(20)
  emergencyContact2Relationship String? @map("emergency_contact_2_relationship") @db.VarChar(20)

  // Profile v3 — address fields for DIRECTOR / SUPER_ADMIN (STAFF reads
  // and writes through Staff.street/city/state/zipCode via the role
  // dispatch in auth.service.updateMyProfile). Same column shapes as
  // Center / Staff so the address rendering helper can stay generic.
  street  String? @db.VarChar(200)
  city    String? @db.VarChar(100)
  state   String? @db.VarChar(2)
  zipCode String? @map("zip_code") @db.VarChar(10)

  // Auth security — populated by the login flow.
  // failedLoginAttempts increments on each bad-password attempt and resets to 0
  // either on a successful login or when lockedUntil is set (the lockout itself
  // becomes the source of truth for "blocked"). lockedUntil is a forward-only
  // timestamp: while > now() the account refuses login with ACCOUNT_LOCKED.
  // lastLoginAt is recorded only on successful login for audit/anomaly review.
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  lastLoginAt         DateTime? @map("last_login_at")

  // Relations
  centerId String? @map("center_id") @db.Uuid
  center   Center? @relation("CenterUsers", fields: [centerId], references: [id])

  staffId String? @unique @map("staff_id") @db.Uuid
  staff   Staff?  @relation(fields: [staffId], references: [id])

  parentId String? @unique @map("parent_id") @db.Uuid
  parent   Parent? @relation(fields: [parentId], references: [id])

  // Reverse relations
  ownedCenters        Center[]             @relation("CenterOwner")
  payrollAdjustments  PayrollAdjustment[]  @relation("PayrollAdjuster")
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]

  // Staff module — back-relation for the CPR verifier FK + invitations.
  // PO QA #46: backgroundChecksVerified relation removed alongside the
  // simplified BG model (no per-check verifier any more — status +
  // approved boolean is all the data we track).
  cprChecksVerified        Staff[]                @relation("StaffCprVerifier")
  staffInvitationsSent     StaffInvitationToken[] @relation("StaffInvitationInviter")

  // Password-admin audit trail (PO QA #28 Opción F). Two directions:
  // actions this user PERFORMED (as Director/SUPER_ADMIN) and actions
  // RECEIVED (as the target user whose password was reset).
  passwordAdminActionsPerformed PasswordAdminAction[] @relation("PasswordAdminActor")
  passwordAdminActionsReceived  PasswordAdminAction[] @relation("PasswordAdminTarget")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  activatedAt DateTime? @map("activated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("users")
}

enum UserRole {
  DIRECTOR
  STAFF
  PARENT
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING_ACTIVATION
  SUSPENDED
  DELETED
}

// Profile v2 — server-persisted time format preference. The two values
// match the client TimeFormat type ('12h' / '24h') — the mapping happens
// at the service/DTO boundary.
enum TimeFormat {
  TWELVE_HOUR
  TWENTY_FOUR_HOUR
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("sessions")
}

// Append-only ledger of admin actions (manual unlocks today; later: status
// changes, role grants, etc.). Not FK-linked to User so a record survives
// the target's deletion. Indexes cover the three lookup patterns: "who did
// what" (actor), "what happened to whom" (target), and chronological scan.
// One-time password reset tokens. Plaintext token lives in the URL only —
// stored here for lookup. `usedAt` makes the token single-use even before
// expiry: claiming it sets the timestamp, subsequent claims fail. `expiresAt`
// kills stale tokens. Cascade delete with user so a deleted account can't
// be hijacked through a leaked token.
model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model AdminAuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorId      String   @map("actor_id") @db.Uuid
  action       String
  targetUserId String?  @map("target_user_id") @db.Uuid
  payload      Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// ============================================
// CENTERS
// ============================================

model Center {
  id   String @id @default(uuid()) @db.Uuid
  name String

  // Address
  street  String
  city    String
  state   String
  zipCode String @map("zip_code")

  // Info
  licenseNumber String? @map("license_number")
  capacity      Int
  phone         String
  email         String
  website       String?
  timezone      String  @default("America/Los_Angeles")

  // Geolocation — staff attendance geo-fencing (Haversine on backend)
  latitude             Float?
  longitude            Float?
  geoFenceRadiusMeters Int     @default(100) @map("geo_fence_radius_meters")

  // Status
  status CenterStatus @default(SETUP_PENDING)

  // KinderCtrl Admin center: a single special center used as a holding area
  // (e.g. a director "in transit" after being removed). Undeletable,
  // unrenamable, status-locked, and hidden from DIRECTOR/STAFF lists.
  isAdminCenter Boolean @default(false) @map("is_admin_center")

  // Relations
  ownerId String @map("owner_id") @db.Uuid
  owner   User   @relation("CenterOwner", fields: [ownerId], references: [id])

  users              User[]                 @relation("CenterUsers")
  staff              Staff[]
  staffInvitations   StaffInvitationToken[]
  parents            Parent[]
  children           Child[]
  classrooms         Classroom[]
  centerHours        CenterHours[]
  milestoneConfigs   MilestoneConfig[]
  pricingConfig      PricingConfig?
  invoices           Invoice[]
  attendance         Attendance[]
  documents          Document[]
  // Staff attendance & time tracking
  staffTimeEntries    StaffTimeEntry[]
  correctionRequests  CorrectionRequest[]
  schedules           Schedule[]
  attendanceApprovals AttendanceApproval[]
  payrollSettings     PayrollSettings?
  payrollPeriods      PayrollPeriod[]
  payrollAdjustments  PayrollAdjustment[]
  kioskSettings       KioskSettings?

  // Timestamps
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  setupCompletedAt DateTime? @map("setup_completed_at")

  @@map("centers")
}

enum CenterStatus {
  SETUP_PENDING
  ACTIVE
  SUSPENDED
  CLOSED
}

model CenterHours {
  id       String @id @default(uuid()) @db.Uuid
  centerId String @map("center_id") @db.Uuid
  center   Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  dayOfWeek Int     @map("day_of_week") // 0-6
  openTime  String  @map("open_time") // "07:00"
  closeTime String  @map("close_time") // "18:00"
  isOpen    Boolean @default(true) @map("is_open")

  @@map("center_hours")
}

// ============================================
// CLASSROOMS
// ============================================

model Classroom {
  id       String @id @default(uuid()) @db.Uuid
  centerId String @map("center_id") @db.Uuid
  center   Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  name         String
  ageMinMonths Int    @map("age_min_months")
  ageMaxMonths Int    @map("age_max_months")
  capacity     Int
  staffRatio   Int    @map("staff_ratio") // 1 staff per X children

  // Relations
  classroomChildren ClassroomChild[]
  classroomStaff    ClassroomStaff[]

  // Stats
  currentEnrollment Int @default(0) @map("current_enrollment")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("classrooms")
}

model ClassroomChild {
  id          String    @id @default(uuid()) @db.Uuid
  classroomId String    @map("classroom_id") @db.Uuid
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  childId String @map("child_id") @db.Uuid
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  enrolledAt DateTime @default(now()) @map("enrolled_at")

  @@unique([classroomId, childId])
  @@map("classroom_children")
}

model ClassroomStaff {
  id          String    @id @default(uuid()) @db.Uuid
  classroomId String    @map("classroom_id") @db.Uuid
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  staffId String @map("staff_id") @db.Uuid
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  isPrimary Boolean @default(false) @map("is_primary")

  @@unique([classroomId, staffId])
  @@map("classroom_staff")
}

// ============================================
// STAFF
// ============================================

model Staff {
  id       String @id @default(uuid()) @db.Uuid
  centerId String @map("center_id") @db.Uuid
  center   Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  // email field intentionally removed (spec §2.2): User.email is the
  // single source of truth. Read via staff.user.email through the 1:1
  // relation (User.staffId @unique → Staff.id).
  role      StaffRole

  // Free-text job title — display + HR reporting only, never used for
  // authorization. role (TEACHER/ASSISTANT/ADMIN) stays the authz axis.
  position  String?   @db.VarChar(50)

  // Optional. Director can leave blank at create; staff fills later from
  // their profile. Date-only column (no time/timezone semantics).
  dateOfBirth DateTime? @map("date_of_birth") @db.Date

  // Self-service profile fields (Opción C). Address is stored as 4
  // discrete columns matching Center's pattern (street/city/state/zip)
  // — all nullable, since Staff fill these in optionally via
  // /profile/complete. PO QA #11 replaced the v1 single-string `address`
  // column with this structured form for consistency with Centers.
  street                String? @db.VarChar(200)
  city                  String? @db.VarChar(100)
  state                 String? @db.VarChar(2)
  zipCode               String? @map("zip_code") @db.VarChar(10)
  emergencyContactName         String? @map("emergency_contact_name") @db.VarChar(100)
  emergencyContactPhone        String? @map("emergency_contact_phone")
  // PO QA #31: relationship + second emergency contact. Relationship is
  // a free-text-with-whitelist string (validated at DTO boundary against
  // ['father','mother','spouse','partner','sibling','friend','other'])
  // instead of a Prisma enum so adding new options later is a no-migration
  // change.
  emergencyContactRelationship String? @map("emergency_contact_relationship") @db.VarChar(20)
  emergencyContact2Name        String? @map("emergency_contact_2_name") @db.VarChar(100)
  emergencyContact2Phone       String? @map("emergency_contact_2_phone")
  emergencyContact2Relationship String? @map("emergency_contact_2_relationship") @db.VarChar(20)
  // Set to true when the staff member saves anything via /staff/me/profile.
  // Drives the "Complete your profile" banner on the dashboard.
  profileComplete        Boolean @default(false) @map("profile_complete")

  hireDate       DateTime @map("hire_date")
  hourlyRate     Decimal? @map("hourly_rate") @db.Decimal(10, 2)
  employmentType String   @map("employment_type") // full_time, part_time

  phone String?
  notes String?

  status StaffStatus @default(INVITED)

  // Kiosk PIN — per-staff 4-digit PIN for clock-in/out at the shared kiosk.
  // Hashed with bcrypt. Locks after 3 failed attempts; the director
  // unlocks/resets. Used ONLY for the kiosk (never for app login).
  kioskPin          String?   @map("kiosk_pin")
  kioskPinFailCount Int       @default(0) @map("kiosk_pin_fail_count")
  kioskPinLocked    Boolean   @default(false) @map("kiosk_pin_locked")
  kioskPinSetAt     DateTime? @map("kiosk_pin_set_at")

  // Background Check compliance — PO QA #46 simplification.
  // `status` models the *process phase* (where the check is in its
  // lifecycle); `approved` carries the *outcome* and only matters when
  // status=COMPLETED (NULL otherwise). The QA #45 verifier FK + date /
  // expiry / notes columns were dropped after PO confirmed the model
  // collapse — there's no per-check audit, only the current state.
  backgroundCheckStatus    BackgroundCheckStatus @default(PENDING) @map("background_check_status")
  backgroundCheckApproved  Boolean?              @map("background_check_approved")

  // CPR / First Aid certification — PO QA #49 simplification.
  // `cprStatus` mirrors the BG #46 model: lifecycle phase explicitly
  // stored, not derived from date. Validation rules at the service
  // layer: ACTIVE requires a future cprExpiryDate, EXPIRED requires a
  // past one; PENDING / CANCELLED don't constrain expiry. The legacy
  // `cprCertified` boolean was dropped (derivable as status IN
  // ('ACTIVE', 'EXPIRED') if external code ever needs it). Provider /
  // notes / verifier columns RETAINED per PO — CPR keeps the richer
  // history that BG didn't need.
  cprStatus                CprStatus @default(PENDING) @map("cpr_status")
  cprCertificationDate     DateTime? @map("cpr_certification_date") @db.Date
  cprExpiryDate            DateTime? @map("cpr_expiry_date") @db.Date
  cprCertificationProvider String?   @map("cpr_certification_provider") @db.VarChar(100)
  cprVerifiedById          String?   @map("cpr_verified_by_id") @db.Uuid
  cprVerifiedBy            User?     @relation("StaffCprVerifier", fields: [cprVerifiedById], references: [id], onDelete: SetNull)
  cprNotes                 String?   @map("cpr_notes")

  // Relations
  user           User?
  classroomStaff ClassroomStaff[]
  // Attendance module
  timeEntries         StaffTimeEntry[]
  payrollAdjustments  PayrollAdjustment[]
  correctionRequests  CorrectionRequest[]
  schedules           Schedule[]
  attendanceApprovals AttendanceApproval[]

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  activatedAt DateTime? @map("activated_at")

  @@index([cprExpiryDate])
  @@index([backgroundCheckStatus])
  @@index([cprStatus])
  @@map("staff")
}

enum StaffRole {
  TEACHER
  ASSISTANT
  ADMIN
}

enum StaffStatus {
  INVITED
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum CprStatus {
  // PO QA #49 — CPR mirror of BG #46. Lifecycle phases only:
  //   PENDING   — newly hired / cert not yet validated
  //   ACTIVE    — cert in force (future expiry required)
  //   EXPIRED   — cert lapsed (past expiry required)
  //   CANCELLED — cert revoked / no longer applicable
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum BackgroundCheckStatus {
  // PO QA #46 — collapsed from 5 states. Process phases only; the
  // outcome (approved / not approved) lives in Staff.backgroundCheckApproved.
  PENDING
  COMPLETED
  CANCELLED
}

// Staff invitation tokens. Mirrors PasswordResetToken's shape exactly so
// the lifecycle (single-use via usedAt, expiry via expiresAt, cascade on
// related-record delete) is identical and predictable. centerId is the
// only "metadata" stored — Director derives from center.owner at accept
// time, no need to denormalize directorId here.
model StaffInvitationToken {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique
  email     String
  centerId  String    @map("center_id") @db.Uuid
  center    Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  // Role frozen at invite time — the invitee can't pick their own role.
  role      StaffRole

  // Audit: who clicked "invite". Nullable + SetNull so a deleted inviter
  // doesn't cascade-delete in-flight invitations.
  invitedById String? @map("invited_by_id") @db.Uuid
  invitedBy   User?   @relation("StaffInvitationInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  expiresAt   DateTime  @map("expires_at")
  // Set the moment an invitee successfully POSTs /staff/accept-invitation.
  // Token becomes single-use after this.
  usedAt      DateTime? @map("used_at")
  // Set when an inviter explicitly cancels via DELETE /staff/invitations/:id
  // (PO QA #13). Distinguishes "cancelled" from "accepted" — both set the
  // token to "no longer usable", but cancelled means "Director took it
  // back" vs accepted means "invitee successfully redeemed".
  cancelledAt  DateTime? @map("cancelled_at")
  // Per-invitation resend rate limit state (PO QA #14 AJUSTE 3). Sliding
  // window: if lastResendAt is >1h ago, the counter is stale and resets
  // to 1 on next resend; otherwise it increments and rejects at 3.
  // Resend NO longer rotates rows — it updates this row in place so the
  // counter stays attached to the invitation across multiple resends.
  lastResendAt DateTime? @map("last_resend_at")
  resendCount  Int       @default(0) @map("resend_count")
  // Optional operational fields the inviter wants pre-populated on the
  // Staff record when this invitation is accepted (PO QA #28 Opción F).
  // Free-form JSON to avoid bikeshedding new columns; the service
  // validates known keys at invite-time and again at accept-time.
  // Known keys (all optional):
  //   hireDate: ISO date string
  //   employmentType: 'full_time' | 'part_time'
  //   hourlyRate: number
  //   position: string
  //   dateOfBirth: ISO date string
  prefillData  Json?     @map("prefill_data")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("staff_invitation_tokens")
}

// Audit log for admin-triggered credential actions (PO QA #28 Opción F).
// Currently only RESET_TRIGGERED — when a Director or SUPER_ADMIN clicks
// "Send Password Reset" on a staff detail page. The actor never sees the
// password itself; the audit only records who triggered the email send
// for whom + when. Indexed on both userIds so "who reset my password?"
// and "what resets has this admin triggered?" queries stay cheap.
model PasswordAdminAction {
  id           String   @id @default(uuid()) @db.Uuid
  actorUserId  String   @map("actor_user_id") @db.Uuid
  actor        User     @relation("PasswordAdminActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetUserId String   @map("target_user_id") @db.Uuid
  target       User     @relation("PasswordAdminTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  // Open string for forward-compat (e.g. future TEMP_PASSWORD_ISSUED,
  // FORCE_PASSWORD_CHANGE). Validated at the service boundary.
  action       String
  // Captured from the request when available; nullable because background
  // jobs / CLI tools don't have one.
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([targetUserId])
  @@index([actorUserId])
  @@map("password_admin_actions")
}

// ============================================
// PARENTS & CHILDREN
// ============================================

model Parent {
  id       String @id @default(uuid()) @db.Uuid
  centerId String @map("center_id") @db.Uuid
  center   Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  firstName      String  @map("first_name")
  lastName       String  @map("last_name")
  email          String
  // Relaxed to optional in Children Fase 1: the new parent-create flow uses the
  // structured HOME/WORK fields below; these legacy columns stay for back-compat
  // (existing rows + future billing) but are no longer required at create time.
  phonePrimary   String? @map("phone_primary")
  phoneSecondary String? @map("phone_secondary")
  // Legacy free-form address (kept, now optional). Superseded by the discrete
  // HOME columns below.
  address Json?

  // Children Fase 1 — structured HOME contact (all optional). Discrete columns
  // mirror Child's address + the Center/Staff street/city/state/zip pattern.
  homePhone         String? @map("home_phone") @db.VarChar(20)
  homeAddressNumber String? @map("home_address_number")
  homeAddressStreet String? @map("home_address_street")
  homeAddressCity   String? @map("home_address_city")
  homeAddressState  String? @map("home_address_state") @db.VarChar(2)
  homeAddressZip    String? @map("home_address_zip") @db.VarChar(10)

  // Children Fase 1 — WORK contact (all optional, contemplated from the start).
  workPhone         String? @map("work_phone") @db.VarChar(20)
  workEmployer      String? @map("work_employer")
  workAddressNumber String? @map("work_address_number")
  workAddressStreet String? @map("work_address_street")
  workAddressCity   String? @map("work_address_city")
  workAddressState  String? @map("work_address_state") @db.VarChar(2)
  workAddressZip    String? @map("work_address_zip") @db.VarChar(10)

  status ParentStatus @default(INVITED)

  // Relations
  user         User?
  childParents ChildParent[]
  invoices     Invoice[]

  // Stripe
  stripeCustomerId String? @map("stripe_customer_id")
  autoPayEnabled   Boolean @default(false) @map("auto_pay_enabled")
  paymentMethodId  String? @map("payment_method_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("parents")
}

enum ParentStatus {
  INVITED
  ACTIVE
  INACTIVE
}

model Child {
  id       String @id @default(uuid()) @db.Uuid
  centerId String @map("center_id") @db.Uuid
  center   Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  // Children Fase 1 — who created the record (audit). Stored as a plain Uuid
  // (no relation) following the codebase pattern for user-id audit columns
  // (Attendance.checkedInBy, Document.uploadedBy, ChildMilestone.markedBy).
  createdByUserId String? @map("created_by_user_id") @db.Uuid

  firstName   String   @map("first_name")
  // Fase 1 — optional middle name.
  middleName  String?  @map("middle_name")
  lastName    String   @map("last_name")
  dateOfBirth DateTime @map("date_of_birth") @db.Date
  // Free-text-with-whitelist (MALE/FEMALE/OTHER) validated at the DTO boundary,
  // mirroring the codebase's choice to avoid enums for small whitelists
  // (Staff.emergencyContactRelationship, ChildParent.relationship) so new
  // values are a no-migration change.
  gender      String
  photoUrl    String?  @map("photo_url")

  // Fase 1 — child's own address + phone (all optional). Discrete columns per
  // the spec (number/street/city/state/zip), snake_cased to match Center/Staff.
  addressNumber String? @map("address_number")
  addressStreet String? @map("address_street")
  addressCity   String? @map("address_city")
  addressState  String? @map("address_state") @db.VarChar(2)
  addressZip    String? @map("address_zip") @db.VarChar(10)
  phone         String? @db.VarChar(20)

  // Renamed from `status` (ChildStatus ACTIVE/WITHDRAWN/GRADUATED, default
  // ACTIVE) to match the spec: enrollment lifecycle, initial PENDING.
  enrollmentStatus ChildStatus @default(PENDING) @map("enrollment_status")

  // Fase 1 — admission + first day of care (both optional, date-only).
  admissionDate DateTime? @map("admission_date") @db.Date
  firstCareDay  DateTime? @map("first_care_day") @db.Date

  // Relations
  childParents      ChildParent[]
  classroomChildren ClassroomChild[]
  attendance        Attendance[]
  dailyLogs         DailyLog[]
  milestones        ChildMilestone[]
  immunizations     Immunization[]
  medicalInfo       ChildMedicalInfo?
  contacts          ChildContact[]
  development       ChildDevelopment?
  invoices          Invoice[]

  // Pre-existing column kept for back-compat (centers stats / future billing).
  // admissionDate is the spec's enrollment-intent date; this stays the
  // record-creation default until a later phase reconciles the two.
  enrollmentDate DateTime @default(now()) @map("enrollment_date")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([centerId, enrollmentStatus])
  @@map("children")
}

enum ChildStatus {
  // Spec Fase 1 — enrollment lifecycle: PENDING (new default), ACTIVE,
  // INACTIVE, WITHDRAWN. GRADUATED is unused in code and not part of the spec,
  // but kept as a tail value: dropping it WHILE renaming status →
  // enrollment_status in the same `db push` breaks Prisma's step ordering
  // (it recreates the enum type and references the not-yet-created column).
  // Adding values is a safe ALTER TYPE ADD VALUE; the dead value can be pruned
  // later in an isolated migration.
  PENDING
  ACTIVE
  INACTIVE
  WITHDRAWN
  GRADUATED
}

// Pivot table
model ChildParent {
  id      String @id @default(uuid()) @db.Uuid
  childId String @map("child_id") @db.Uuid
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  parentId String @map("parent_id") @db.Uuid
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  // Free-text-with-whitelist (MOTHER/FATHER/GUARDIAN/OTHER) validated at the
  // DTO boundary — same no-enum convention as Child.gender.
  relationship    String
  isPrimary       Boolean @default(false) @map("is_primary")
  // Fase 1 — whether the parent lives with the child.
  livesWithChild  Boolean @default(false) @map("lives_with_child")
  // Pre-existing pickup/updates flags kept (additive; no code depends on them
  // yet, but they're harmless and may surface in a later phase).
  canPickup       Boolean @default(true) @map("can_pickup")
  receivesUpdates Boolean @default(true) @map("receives_updates")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([childId, parentId])
  @@map("child_parents")
}

model ChildMedicalInfo {
  id      String @id @default(uuid()) @db.Uuid
  childId String @unique @map("child_id") @db.Uuid
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  allergies         Json // array of strings
  medications       Json // array of objects
  medicalConditions Json // array of strings

  doctorName    String? @map("doctor_name")
  doctorPhone   String? @map("doctor_phone")
  // Fase 1 — added per spec.
  doctorAddress String? @map("doctor_address")

  // Fase 1 — free-text fields per spec. `medicationAllergies` is distinct from
  // `allergies` (the latter stays the structured Json list); `medicalPlan`
  // captures the care/action plan; `hasSpecialNeeds` is the boolean flag.
  medicationAllergies String?  @map("medication_allergies")
  medicalPlan         String?  @map("medical_plan")
  hasSpecialNeeds     Boolean  @default(false) @map("has_special_needs")

  insuranceProvider String? @map("insurance_provider")
  insurancePolicy   String? @map("insurance_policy")

  // Fase 2 (2A) — extended medical history per SPEC-Children-Fase2-2A.
  // Doctor's care + last exam.
  isUnderDoctorCare  Boolean   @default(false) @map("is_under_doctor_care")
  doctorLastExamDate DateTime? @map("doctor_last_exam_date") @db.Date

  // LIC 702 splits medication into "what kind" + "any side effects", so these
  // are two distinct free-text columns. Both are separate from the structured
  // `medications` Json list (Fase 1) and from `medicationAllergies`.
  prescribedMedicationDetails String? @map("prescribed_medication_details")
  medicationSideEffects       String? @map("medication_side_effects")

  // Dentist contact + dental plan. Address is structured (street/city/state/zip)
  // via the shared AddressFields layout — discrete columns, unlike the Fase 1
  // doctorAddress single text field (kept as-is).
  dentistName         String? @map("dentist_name")
  dentistPhone        String? @map("dentist_phone")
  dentistAddressStreet String? @map("dentist_address_street")
  dentistAddressCity   String? @map("dentist_address_city")
  dentistAddressState  String? @map("dentist_address_state") @db.VarChar(2)
  dentistAddressZip    String? @map("dentist_address_zip") @db.VarChar(10)
  dentalPlan          String? @map("dental_plan")

  // Special devices the child uses (glasses, hearing aids, braces, etc.).
  specialDevices String? @map("special_devices")

  // Frequent colds flag + how many per year.
  frequentColds      Boolean @default(false) @map("frequent_colds")
  frequentColdsCount Int?    @map("frequent_colds_count")

  // Past-illness checklist. Json object keyed by the CHILD_PAST_ILLNESSES
  // whitelist (Chicken Pox, Asthma, … Three-Day Measles), each value
  // { checked: boolean, date?: string }. Nullable so legacy rows stay untouched
  // and adding/removing list items is a no-migration change.
  pastIllnesses  Json?   @map("past_illnesses")
  otherIllnesses String? @map("other_illnesses")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("child_medical_info")
}

// Fase 2 (2A) — emergency / authorized-pickup / responsible contacts for a
// child. Single table with a `contactType` discriminator (all three types share
// the same fields, so 3 separate tables would only triple the surface area for
// no gain). `contactType` is a free-text-with-whitelist string validated at the
// DTO boundary (EMERGENCY/AUTHORIZED_PICKUP/RESPONSIBLE) — same no-enum
// convention as Child.gender / ChildParent.relationship.
model ChildContact {
  id      String @id @default(uuid()) @db.Uuid
  childId String @map("child_id") @db.Uuid
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  contactType  String  @map("contact_type")
  name         String
  relationship String?
  phone        String? @db.VarChar(20)
  homePhone    String? @map("home_phone") @db.VarChar(20)
  workPhone    String? @map("work_phone") @db.VarChar(20)
  // Structured address (street/city/state/zip) via the shared AddressFields.
  addressStreet String? @map("address_street")
  addressCity   String? @map("address_city")
  addressState  String? @map("address_state") @db.VarChar(2)
  addressZip    String? @map("address_zip") @db.VarChar(10)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([childId, contactType])
  @@map("child_contacts")
}

// Fase 2 (2B) — developmental & daily-care intake profile for a child. ONE 1:1
// satellite (mirrors ChildMedicalInfo's single-table design) holding three
// logical sections: developmental milestones, daily routines, and toileting.
// They're all one-record-per-child intake data filled on the same edit surface,
// so — per the ChildContact note above ("3 separate tables would only triple
// the surface area for no gain") — they live in one table grouped by comment,
// not three. Written via a full-replace upsert (PUT /children/:id/development),
// exactly like ChildMedicalInfo.
model ChildDevelopment {
  id      String @id @default(uuid()) @db.Uuid
  childId String @unique @map("child_id") @db.Uuid
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  // ── DESARROLLO — self-reported developmental milestones (intake history).
  // Deliberately DISTINCT from the ChildMilestone / MilestoneConfig system
  // (ongoing CDC-style assessment): these are one-time historical facts the
  // family reports at enrollment — "age in months when the child first did X".
  // Nullable ints, range-checked 0..120 at the DTO boundary.
  walkedAtMonths        Int?    @map("walked_at_months")
  talkedAtMonths        Int?    @map("talked_at_months")
  toiletTrainedAtMonths Int?    @map("toilet_trained_at_months")
  developmentNotes      String? @map("development_notes")

  // ── RUTINAS DIARIAS — daily routine. Times are "HH:mm" strings (no tz),
  // matching the codebase convention for clock-times (CenterHours.openTime,
  // ScheduleDay.startTime). Nap is a boolean + an optional window.
  wakeUpTime   String? @map("wake_up_time")
  bedTime      String? @map("bed_time")
  takesNap     Boolean @default(false) @map("takes_nap")
  napStartTime String? @map("nap_start_time")
  napEndTime   String? @map("nap_end_time")
  diet         String? // diet / restrictions (free-text)
  mealTimes    String? @map("meal_times")

  // ── TOILET / BAÑO.
  toiletTrained   Boolean @default(false) @map("toilet_trained")
  // Words the child uses to signal the need (free-text).
  toiletWords     String? @map("toilet_words")
  // Level of help the child needs — free-text-with-whitelist (CHILD_TOILET_HELP_LEVELS),
  // validated at the DTO boundary; same no-enum convention as contactType.
  toiletHelpLevel String? @map("toilet_help_level")
  // Accidents: frequency / notes (free-text).
  toiletAccidents String? @map("toilet_accidents")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("child_development")
}

// ============================================
// ATTENDANCE & DAILY OPERATIONS
// ============================================

model Attendance {
  id      String @id @default(uuid()) @db.Uuid
  childId String @map("child_id") @db.Uuid
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  centerId String @map("center_id") @db.Uuid
  center   Center @relation(fields: [centerId], references: [id])

  date         DateTime  @db.Date
  checkInTime  DateTime  @map("check_in_time")
  checkOutTime DateTime? @map("check_out_time")

  checkedInBy  String  @map("checked_in_by") @db.Uuid // user_id
  checkedOutBy String? @map("checked_out_by") @db.Uuid

  checkInMethod String           @map("check_in_method") // qr_code, pin, manual
  status        AttendanceStatus @default(CHECKED_IN)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([childId, date])
  @@index([childId, date])
  @@map("attendance")
}

enum AttendanceStatus {
  CHECKED_IN
  CHECKED_OUT
}

model DailyLog {
  id      String @id @default(uuid()) @db.Uuid
  childId String @map("child_id") @db.Uuid
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  date DateTime @db.Date

  // Morning
  temperatureMorning Decimal? @map("temperature_morning") @db.Decimal(4, 1)
  moodMorning        String?  @map("mood_morning")
  symptoms           Json?

  // Meals (stored as JSON)
  meals Json // { breakfast: {...}, lunch: {...}, snack: {...} }

  // Nap
  nap Json // { start_time, end_time, duration_minutes, quality }

  // Activities
  activities Json // array of activity objects

  // Other
  diaperChanges Json @default("[]") @map("diaper_changes")
  observations  Json @default("[]")
  photos        Json @default("[]")

  // Report
  reportSent   Boolean   @default(false) @map("report_sent")
  reportSentAt DateTime? @map("report_sent_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([childId, date])
  @@index([childId, date])
  @@map("daily_logs")
}

