# Database
DATABASE_URL=postgresql://user:password@localhost:5432/kinderctrl?schema=public

# JWT
JWT_SECRET=change-this-in-production-super-secret-key-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change-this-refresh-secret-key-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# Encryption (para datos sensibles)
ENCRYPTION_KEY=change-this-32-byte-hex-key-for-aes256-encryption

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CLIENT_ID=ca_your_client_id_for_connect

# SendGrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@kinderctrl.com

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=kinderctrl-xxxxx
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYour-Key-Here\n-----END PRIVATE KEY-----
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@kinderctrl-xxxxx.iam.gserviceaccount.com

# Redis (Upstash)
REDIS_URL=redis://default:your_password@your-redis-url.upstash.io:6379

# Cloudflare R2 (File Storage)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=kinderctrl-uploads
R2_PUBLIC_URL=https://your-bucket-url.r2.dev

# Sentry (Error Tracking)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# App Config
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
API_PREFIX=api/v1

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100